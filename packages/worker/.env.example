# Environment Configuration for Desktop Agent Worker
# Copy this file to .env and fill in your values
# For non-production environments, you can use .env.dev, .env.staging, etc.

# General Environment Settings
# ----------------------------
ENV=dev
KEYRING_SERVICE_NAME=desktop-agent

# Database Configuration
# ----------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_NAME=postgres

# SAP Configuration
# ----------------------------
SAP_USERNAME=your_sap_username
SAP_PASSWORD=your_sap_password
SAP_CONNECTION_NAME=SAP 340 Quality
SAP_WINDOW_TITLE=SAP Logon 770

# API Configuration
# ----------------------------
API_KEY=your_api_key_here
API_KEY_HEADER=X-API-Key
API_BASE_URL=http://localhost:8000/api/v1

# Logging Configuration
# ----------------------------
LOG_LEVEL=INFO
LOG_FORMAT=None
LOG_ROTATION=100 MB
LOG_RETENTION=7 days
LOG_COMPRESSION=zip
LOG_COLORIZE=true
LOG_FILE=None
LOG_ERROR_FILE=None

# Worker Configuration
# --------------------
WORKER_CONCURRENCY=1
WORKER_QUEUES=None
WORKER_IMPORT_PATHS='["worker.tasks"]'

