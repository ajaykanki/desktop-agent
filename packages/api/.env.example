ENV=dev

# API Configuration
# ----------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_KEY_HEADER=X-API-Key
API_PREFIX=/api/v1
API_TITLE=Task Queue API
API_VERSION=0.1.0
API_DESCRIPTION=A distributed task execution system with FastAPI server for task queue and workers for task execution

# Database Configuration
# ----------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=postgres


# Logging Configuration
# ----------------------------
LOG_LEVEL=INFO
LOG_FORMAT=
LOG_ROTATION=100 MB
LOG_RETENTION=7 days
LOG_COMPRESSION=zip
LOG_COLORIZE=true
LOG_FILE=None
LOG_ERROR_FILE=None
